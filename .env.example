# ── API ───────────────────────────────────────────────────────────────────────
# Base URL of the PHP backend, no trailing slash.
# Local dev: http://localhost:8080  |  Production: https://your-api-domain.com
NEXT_PUBLIC_API_URL=

# localStorage key used to store the session token (default: enewton-token).
NEXT_PUBLIC_TOKEN_KEY=enewton-token

# ── Pusher ────────────────────────────────────────────────────────────────────
# Public app key and cluster — safe to expose to the browser (NEXT_PUBLIC_*).
# Find these in the Pusher dashboard → App Keys.
# PUSHER_APP_SECRET must never be added here — it belongs in the API env only.
NEXT_PUBLIC_PUSHER_APP_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
# Used server-side (Next.js API routes) to upload bracelet preview images.
ENEWTON_AWS_ACCESS_KEY_ID=
ENEWTON_AWS_SECRET_ACCESS_KEY=
ENEWTON_AWS_REGION=us-east-1
S3_BUCKET_NAME=
